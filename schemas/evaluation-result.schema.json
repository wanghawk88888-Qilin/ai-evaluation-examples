{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvaluationResult",
  "type": "object",
  "required": ["case_id", "passed", "score", "criteria_results"],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "passed": {
      "type": "boolean"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "criteria_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "passed", "reason"],
        "properties": {
          "criterion": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
